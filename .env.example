# MedBridge Health Coach — Environment Variables

# Environment
ENVIRONMENT=dev
DEBUG=false

# Database (PostgreSQL for production, SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./health_coach.db
# DATABASE_URL=postgresql+psycopg://health_coach:password@localhost:5432/health_coach

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# App
APP_MODE=all
HOST=0.0.0.0
PORT=8000
